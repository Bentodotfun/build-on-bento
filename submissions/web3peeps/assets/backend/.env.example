# =============================================================================
# TruthMarket Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---

# Bento testnet builder API key (mint one via Bento's hackathon form)
BENTO_BUILDER_API_KEY=

# Bento testnet host
BENTO_URL=https://internal-server.bento.fun

# Anakin AI API key (sign up at https://anakin.io)
ANAKIN_API_KEY=

# OpenRouter API key (for AI claim normalization, hook lines, assessments)
OPENROUTER_API_KEY=

# MongoDB Atlas connection string
MONGODB_URI=

# Random string used to encrypt user wallet private keys
ENCRYPTION_KEY=

# Server port
PORT=4000

# --- Optional ---

# OpenRouter model override (default: tencent/hy3:free)
# OPENROUTER_MODEL=tencent/hy3:free

# Site URL sent in OpenRouter HTTP-Referer header (helps with rankings)
# OPENROUTER_SITE_URL=http://localhost:4000

# App name sent in OpenRouter X-Title header
# OPENROUTER_APP_NAME=TruthMarket

# --- X API (optional, requires paid X account as of Feb 2026) ---
# Enable auto-reply posting (default: false)
# X_API_ENABLED=false
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# X_BEARER_TOKEN=
