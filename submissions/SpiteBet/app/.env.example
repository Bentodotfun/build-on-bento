# --- Server-side only (never exposed to the browser) ---------------------
# Bento testnet builder key: https://docs.bento.fun/concepts/builder-api-key
testnet_builder_api_key=

# Anakin Wire scraping API: https://anakin.io/dashboard
ANAKIN_API_KEY=

# Groq (Llama 3.3 70B) — the oracle's commit-quality judge
GROQ_API_KEY=

# --- Exposed to the client bundle (VITE_ prefix) -------------------------
# Testnet keys only. Never put a mainnet key here.
VITE_BENTO_BUILDER_API_KEY=

# Demo accounts for the "playing as" switcher. Each is a real Bento testnet
# account with its own JWT, so every bet is attributed to a distinct user and
# uniqueParticipants counts them separately.
#
# To generate one:
#   1. Sign in at https://testnet.bento.fun with a Google account
#   2. node scripts/bento-login.mjs          → prints a connect URL
#   3. Open it while signed in as that account, copy the ?code= from the redirect
#   4. node scripts/bento-login.mjs <code>   → prints the lines to paste below
#
# Tokens last ~7 days. Add up to 8 accounts.
VITE_BENTO_ACCOUNT_1_NAME=
VITE_BENTO_ACCOUNT_1_JWT=
VITE_BENTO_ACCOUNT_2_NAME=
VITE_BENTO_ACCOUNT_2_JWT=
